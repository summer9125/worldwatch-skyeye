# WorldWatch 天眼 - 环境配置

# 应用配置
APP_NAME=WorldWatch 天眼
APP_VERSION=1.0.0
DEBUG=true

# 服务器配置
HOST=0.0.0.0
PORT=8001

# 数据库配置（SQLite 简化版，无需 MySQL）
DATABASE_URL=sqlite:///./worldwatch.db

# Redis 配置（可选）
REDIS_URL=redis://localhost:6379/0

# API 配置（可选）
# WORLD_MONITOR_API_KEY=
# CLOUDFLARE_API_KEY=

# 飞书配置（可选）
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_WEBHOOK=
