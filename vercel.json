{
  "version": 2,
  "builds": [
    {
      "src": "app/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "app/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "app/static/$1"
    }
  ],
  "outputDirectory": "app/static",
  "env": {
    "PYTHON_VERSION": "3.9"
  }
}
